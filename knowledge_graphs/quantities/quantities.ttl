                    si:hasNumericExponent "-3"^^xsd:short ;
                    si:hasUnitBase units:metre ] ] .

quantities:AMSU a si:QuantityKind ;
    skos:altLabel "AMSU"^^xsd:string ;
    skos:prefLabel "amount of substance"@en,
        "quantité de matière"@fr ;
